{
  "name": "lintel",
  "displayName": "ARC — Audit Ready Core",
  "description": "Governed code enforcement for AI-assisted development in a local-first VS Code extension.",
  "version": "0.1.0",
  "private": true,
  "publisher": "swd",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "governance",
    "code quality",
    "audit",
    "compliance",
    "enforcement",
    "local-first",
    "save governance",
    "blueprint proof",
    "audit trail"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/habrahgithub/lintel.git"
  },
  "bugs": {
    "url": "https://github.com/habrahgithub/lintel/issues"
  },
  "homepage": "https://github.com/habrahgithub/lintel#readme",
  "icon": "Public/Logo/ARC LOGO.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:arc.showWelcome",
    "onCommand:arc.reviewAudit",
    "onCommand:arc.showRuntimeStatus",
    "onCommand:arc.reviewBlueprints",
    "onCommand:arc.reviewFalsePositives",
    "onCommand:lintel.showWelcome",
    "onCommand:lintel.reviewAudit",
    "onCommand:lintel.showRuntimeStatus",
    "onCommand:lintel.reviewBlueprints",
    "onCommand:lintel.reviewFalsePositives",
    "onCommand:arc.ui.reviewHome",
    "onCommand:arc.ui.runtimeStatus",
    "onCommand:arc.ui.auditReview",
    "onCommand:arc.ui.blueprintProof",
    "onCommand:arc.ui.falsePositiveReview",
    "onCommand:arc.ui.guidedWorkflow"
  ],
  "contributes": {
    "commands": [
      {
        "command": "arc.showWelcome",
        "title": "ARC: Show Welcome Guide"
      },
      {
        "command": "arc.reviewAudit",
        "title": "ARC: Review Audit Log"
      },
      {
        "command": "arc.showRuntimeStatus",
        "title": "ARC: Show Active Workspace Status"
      },
      {
        "command": "arc.reviewBlueprints",
        "title": "ARC: Review Blueprint Proofs"
      },
      {
        "command": "arc.reviewFalsePositives",
        "title": "ARC: Review False-Positive Candidates"
      },
      {
        "command": "arc.ui.reviewHome",
        "title": "ARC: Review Home"
      },
      {
        "command": "arc.ui.runtimeStatus",
        "title": "ARC: Runtime Status"
      },
      {
        "command": "arc.ui.auditReview",
        "title": "ARC: Audit Review"
      },
      {
        "command": "arc.ui.blueprintProof",
        "title": "ARC: Blueprint Proof Review"
      },
      {
        "command": "arc.ui.falsePositiveReview",
        "title": "ARC: False-Positive Review"
      },
      {
        "command": "arc.ui.guidedWorkflow",
        "title": "ARC: Guided Proof Workflow"
      }
    ]
  },
  "main": "./dist/extension.js",
  "scripts": {
    "audit:cli": "node ./dist/cli.js",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:governance": "vitest run tests/governance",
    "smoke:harness": "node ./scripts/smoke_harness.js",
    "pack": "vsce package --no-dependencies --allow-missing-repository",
    "pack:release": "vsce package --no-dependencies --allow-missing-repository --out ./dist/release/"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
