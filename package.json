{
  "name": "arc-audit-ready-core",
  "displayName": "ARC XT — Audit Ready Core",
  "description": "Governed code enforcement for AI-assisted development in a local-first VS Code extension. Public beta candidate for ARC XT.",
  "version": "0.1.12",
  "preview": true,
  "private": true,
  "publisher": "swd",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "audit",
    "audit layer",
    "accountability",
    "traceability",
    "tamper-evident",
    "hash chain",
    "decision log",
    "ai-assisted coding",
    "ide"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/habrahgithub/lintel.git"
  },
  "bugs": {
    "url": "https://github.com/habrahgithub/lintel/issues"
  },
  "homepage": "https://github.com/habrahgithub/lintel#readme",
  "icon": "Public/Logo/ARC-ICON-1024.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "arc.showWelcome",
        "title": "ARC XT: Show Welcome Guide"
      },
      {
        "command": "arc.showDecisionTimeline",
        "title": "ARC: Show Decision Timeline"
      },
      {
        "command": "arc.reviewAudit",
        "title": "ARC XT: Review Audit Log"
      },
      {
        "command": "arc.showRuntimeStatus",
        "title": "ARC XT: Show Active Workspace Status"
      },
      {
        "command": "arc.reviewBlueprints",
        "title": "ARC XT: Review Blueprint Proofs"
      },
      {
        "command": "arc.reviewFalsePositives",
        "title": "ARC XT: Review False-Positive Candidates"
      },
      {
        "command": "arc.ui.reviewHome",
        "title": "ARC XT: Review Home"
      },
      {
        "command": "arc.ui.runtimeStatus",
        "title": "ARC XT: Runtime Status"
      },
      {
        "command": "arc.ui.auditReview",
        "title": "ARC XT: Audit Review"
      },
      {
        "command": "arc.ui.blueprintProof",
        "title": "ARC XT: Blueprint Proof Review"
      },
      {
        "command": "arc.ui.falsePositiveReview",
        "title": "ARC XT: False-Positive Review"
      },
      {
        "command": "arc.ui.guidedWorkflow",
        "title": "ARC XT: Guided Proof Workflow"
      },
      {
        "command": "arc.ui.decisionFeed",
        "title": "ARC XT: Decision Feed"
      },
      {
        "command": "arc.ui.auditTimeline",
        "title": "ARC XT: Audit Timeline"
      },
      {
        "command": "arc.ui.whyPanel",
        "title": "ARC XT: Why Panel"
      },
      {
        "command": "arc.ui.taskBoard",
        "title": "ARC XT: Task Board"
      },
      {
        "command": "arc.explainCurrentFileState",
        "title": "ARC: Explain Current File State"
      },
      {
        "command": "arc.selectTask",
        "title": "ARC: Select Active Task"
      },
      {
        "command": "arc.clearActiveTask",
        "title": "ARC: Clear Active Task"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "arc-xt-container",
          "title": "ARC XT",
          "icon": "Public/Logo/arc-activitybar.svg"
        }
      ]
    },
    "views": {
      "arc-xt-container": [
        {
          "type": "webview",
          "id": "arc.ui.taskBoard",
          "name": "Task Board",
          "icon": "$(tasklist)",
          "contextualTitle": "ARC XT Task Board"
        }
      ]
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "audit:cli": "node ./dist/cli.js",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:governance": "vitest run tests/governance",
    "test:performance": "vitest run tests/performance",
    "smoke:harness": "node ./scripts/smoke_harness.js",
    "pack": "vsce package --allow-missing-repository",
    "pack:release": "vsce package --allow-missing-repository --out ./dist/release/"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "dependencies": {
    "ajv": "^8.18.0"
  }
}
