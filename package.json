{
  "name": "lintel",
  "displayName": "ARC — Audit Ready Core",
  "description": "Governed code enforcement for AI-assisted development in a local-first VS Code extension.",
  "version": "0.1.0",
  "private": true,
  "publisher": "swd",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:lintel.showWelcome",
    "onCommand:lintel.reviewAudit",
    "onCommand:lintel.showRuntimeStatus",
    "onCommand:lintel.reviewBlueprints",
    "onCommand:lintel.reviewFalsePositives"
  ],
  "contributes": {
    "commands": [
      {
        "command": "lintel.showWelcome",
        "title": "ARC: Show Welcome Guide"
      },
      {
        "command": "lintel.reviewAudit",
        "title": "ARC: Review Audit Log"
      },
      {
        "command": "lintel.showRuntimeStatus",
        "title": "ARC: Show Active Workspace Status"
      },
      {
        "command": "lintel.reviewBlueprints",
        "title": "ARC: Review Blueprint Proofs"
      },
      {
        "command": "lintel.reviewFalsePositives",
        "title": "ARC: Review False-Positive Candidates"
      }
    ]
  },
  "main": "./dist/extension.js",
  "scripts": {
    "audit:cli": "node ./dist/cli.js",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:governance": "vitest run tests/governance",
    "smoke:harness": "node ./scripts/smoke_harness.js",
    "pack": "vsce package --no-dependencies --allow-missing-repository",
    "pack:release": "vsce package --no-dependencies --allow-missing-repository --out ./dist/release/"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
