{
  "name": "arc-audit-ready-core",
  "displayName": "ARC XT — Audit Ready Core",
  "description": "Governed code enforcement for AI-assisted development in a local-first VS Code extension. Public beta candidate for ARC XT.",
  "version": "0.1.7",
  "preview": true,
  "private": true,
  "publisher": "swd",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "governance",
    "code quality",
    "audit",
    "compliance",
    "enforcement",
    "local-first",
    "save governance",
    "blueprint proof",
    "audit trail"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/habrahgithub/arc-extension.git"
  },
  "bugs": {
    "url": "https://github.com/habrahgithub/arc-extension/issues"
  },
  "homepage": "https://github.com/habrahgithub/arc-extension#readme",
  "icon": "Public/Logo/ARC-ICON-1024.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:arc.showWelcome",
    "onCommand:arc.reviewAudit",
    "onCommand:arc.showRuntimeStatus",
    "onCommand:arc.reviewBlueprints",
    "onCommand:arc.reviewFalsePositives",
    "onCommand:lintel.showWelcome",
    "onCommand:lintel.reviewAudit",
    "onCommand:lintel.showRuntimeStatus",
    "onCommand:lintel.reviewBlueprints",
    "onCommand:lintel.reviewFalsePositives",
    "onCommand:arc.ui.reviewHome",
    "onCommand:arc.ui.runtimeStatus",
    "onCommand:arc.ui.auditReview",
    "onCommand:arc.ui.blueprintProof",
    "onCommand:arc.ui.falsePositiveReview",
    "onCommand:arc.ui.guidedWorkflow",
    "onCommand:arc.ui.decisionFeed",
    "onCommand:arc.ui.auditTimeline",
    "onCommand:arc.ui.whyPanel",
    "onCommand:arc.ui.taskBoard",
    "onCommand:arc.createMinimalRoutePolicy",
    "onCommand:arc.createMinimalWorkspaceMapping",
    "onCommand:arc.createMinimalArcConfig"
  ],
  "contributes": {
    "commands": [
      {
        "command": "arc.showWelcome",
        "title": "ARC XT: Show Welcome Guide"
      },
      {
        "command": "arc.reviewAudit",
        "title": "ARC XT: Review Audit Log"
      },
      {
        "command": "arc.showRuntimeStatus",
        "title": "ARC XT: Show Active Workspace Status"
      },
      {
        "command": "arc.reviewBlueprints",
        "title": "ARC XT: Review Blueprint Proofs"
      },
      {
        "command": "arc.reviewFalsePositives",
        "title": "ARC XT: Review False-Positive Candidates"
      },
      {
        "command": "arc.ui.reviewHome",
        "title": "ARC XT: Review Home"
      },
      {
        "command": "arc.ui.runtimeStatus",
        "title": "ARC XT: Runtime Status"
      },
      {
        "command": "arc.ui.auditReview",
        "title": "ARC XT: Audit Review"
      },
      {
        "command": "arc.ui.blueprintProof",
        "title": "ARC XT: Blueprint Proof Review"
      },
      {
        "command": "arc.ui.falsePositiveReview",
        "title": "ARC XT: False-Positive Review"
      },
      {
        "command": "arc.ui.guidedWorkflow",
        "title": "ARC XT: Guided Proof Workflow"
      },
      {
        "command": "arc.ui.decisionFeed",
        "title": "ARC XT: Decision Feed"
      },
      {
        "command": "arc.ui.auditTimeline",
        "title": "ARC XT: Audit Timeline"
      },
      {
        "command": "arc.ui.whyPanel",
        "title": "ARC XT: Why Panel"
      },
      {
        "command": "arc.ui.taskBoard",
        "title": "ARC XT: Task Board"
      },
      {
        "command": "arc.createMinimalRoutePolicy",
        "title": "ARC XT: Create Minimal Route Policy"
      },
      {
        "command": "arc.createMinimalWorkspaceMapping",
        "title": "ARC XT: Create Minimal Workspace Mapping"
      },
      {
        "command": "arc.createMinimalArcConfig",
        "title": "ARC XT: Create Minimal ARC Config (Both)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "arc-xt-container",
          "title": "ARC XT",
          "icon": "Public/Logo/ARC-ICON-1024.png"
        }
      ]
    },
    "views": {
      "arc-xt-container": [
        {
          "type": "webview",
          "id": "arc.ui.taskBoard",
          "name": "Task Board",
          "icon": "$(tasklist)",
          "contextualTitle": "ARC XT Task Board"
        }
      ]
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "audit:cli": "node ./dist/cli.js",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:governance": "vitest run tests/governance",
    "test:performance": "vitest run tests/performance",
    "smoke:harness": "node ./scripts/smoke_harness.js",
    "pack": "vsce package --no-dependencies --allow-missing-repository",
    "pack:release": "vsce package --no-dependencies --allow-missing-repository --out ./dist/release/"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
