# ARC XT VSIX Packaging Boundary
# ARCXT-PKG-001 — Clean Baseline Release

# ===========================================
# EXCLUDE: Evidence bundles and artifacts (OBS-S-7092)
# ===========================================
artifacts/**
.arc/**
.continue/**
test-evidence/**

# ===========================================
# EXCLUDE: Design assets (reference only, not runtime)
# ===========================================
Public/* Template/**

# ===========================================
# EXCLUDE: Test files
# ===========================================
tests/**
test/**
vitest.config.ts
vitest.config.mts
vitest.config.js
coverage/**
.nyc_output/**

# ===========================================
# EXCLUDE: Version control and IDE residue
# ===========================================
.git/**
.gitignore
.svn/**
.vscode/**
*.code-workspace

# ===========================================
# EXCLUDE: Source TypeScript (ship dist/ only)
# ===========================================
src/**
*.ts
*.tsbuildinfo
*.map

# ===========================================
# EXCLUDE: Local config residue
# ===========================================
.env
.env.*
!.env.example
*.local
*.local.*
.eslintrc.*
eslint.config.*
.prettierrc
.prettierignore
tsconfig.*
jsconfig.*

# ===========================================
# EXCLUDE: Scripts not needed at runtime
# ===========================================
scripts/**
tools/**

# Exclude TypeScript source from node_modules dependencies
node_modules/**/*.ts
node_modules/**/*.d.ts
node_modules/**/*.md

# ===========================================
# EXCLUDE: Logs and temp files
# ===========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db
*.bak
*.swp
*~

# ===========================================
# EXCLUDE: Internal governance docs (keep README)
# ===========================================
AGENTS.md
LINTEL-*.md
PHASE*.md
BUILD-*.md
HARDENING-*.md
ACTIVATION-*.md

# Exclude entire docs directory except README
docs/**
!docs/README.md

# ===========================================
# KEEP: Required runtime files (whitelist)
# ===========================================
!package.json
!README.md
!dist/**
!node_modules/ajv/dist/**
!node_modules/fast-deep-equal/**
!node_modules/fast-uri/dist/**
!node_modules/json-schema-traverse/**
!node_modules/require-from-string/**
!rules/**
!Public/Logo/**
!LICENSE

